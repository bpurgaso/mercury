# ─────────────────────────────────────────────────────────────────────────────
# Mercury — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env
#
# All MERCURY_ prefixed variables override their corresponding keys in
# src/server/config/default.toml.  For example:
#
#   MERCURY_SERVER_PORT  →  [server] port
#   MERCURY_AUTH_JWT_SECRET  →  [auth] jwt_secret
#
# See server-spec.md §8.1–8.2 for the full configuration reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────

# Host and port the Mercury server binds to
MERCURY_SERVER_HOST=0.0.0.0
MERCURY_SERVER_PORT=8443

# Public-facing hostname — used for TURN realm, ICE candidates, and invite links.
# For local dev this should be "localhost". In production, set to your actual domain.
PUBLIC_DOMAIN=localhost

# ── Database (Postgres) ─────────────────────────────────────────────────────

# Connection string used by the Mercury server at runtime.
MERCURY_DATABASE_URL=postgres://mercury:mercury@localhost:5432/mercury

# Postgres container credentials (used by docker-compose to initialize the DB).
# These must match the user/password/dbname in MERCURY_DATABASE_URL.
POSTGRES_USER=mercury
POSTGRES_PASSWORD=mercury
POSTGRES_DB=mercury

# ── Redis ────────────────────────────────────────────────────────────────────

MERCURY_REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────────────────────

# JWT signing secret. CHANGE THIS in production — use a random 64+ character string.
# Generate one with:  openssl rand -base64 48
MERCURY_AUTH_JWT_SECRET=dev-secret-change-in-production

# ── TLS ──────────────────────────────────────────────────────────────────────

# Paths to TLS certificate and private key.
# For local dev, generate these with:  ./scripts/generate-certs.sh
# The certs/ directory is mounted into Docker containers by docker-compose.yml.
MERCURY_TLS_CERT_PATH=./certs/cert.pem
MERCURY_TLS_KEY_PATH=./certs/key.pem

# ── TURN Server (coturn) ────────────────────────────────────────────────────

# Shared secret between Mercury server and coturn for generating time-limited
# TURN credentials. Both the server and coturn must use the same value.
# CHANGE THIS in production — use a random 64+ character string.
# Generate one with:  openssl rand -base64 48
TURN_SECRET=mercury-turn-dev-secret

# ── Logging ──────────────────────────────────────────────────────────────────

# Rust tracing filter syntax. Controls server log verbosity.
# Examples:
#   mercury=debug,tower_http=debug    (verbose — good for dev)
#   mercury=info                       (standard — good for production)
#   mercury=warn                       (quiet — errors and warnings only)
RUST_LOG=mercury=debug,tower_http=debug
